# ─── Hutchrok Solutions Group — Environment Variables ───
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local (it is already in .gitignore).
#
# These same variables must be set in Vercel:
#   Dashboard → Project → Settings → Environment Variables
# ────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────

# Supabase project URL (Settings → API in Supabase dashboard)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon/public key (Settings → API in Supabase dashboard)
SUPABASE_ANON_KEY=eyJhbGciOiJI...your-anon-key

# Shared secret that protects the /admin console and admin API routes.
# Generate one: openssl rand -base64 32
ADMIN_TOKEN=replace-with-a-strong-random-secret

# Clerk authentication (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── OPTIONAL ──────────────────────────────────────────

# Ops integration token for inbound Power Automate / external webhooks.
# Required when /api/ops/* endpoints are used.
# Generate one: openssl rand -base64 32
# OPS_TOKEN=replace-with-a-strong-random-secret

# Outbound ops webhook URL (for case event notifications to Power Automate).
# Leave empty/commented to disable outbound ops events.
# OPS_WEBHOOK_URL=https://prod-xx.westus.logic.azure.com/...

# Resend API key for paid service request emails.
# Required for /api/service-request to deliver submissions to contact@hutchrok.com.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

# Optional sender identity for service request emails.
# Defaults to "Hutchrok Intake <onboarding@resend.dev>" when not set.
# RESEND_FROM_EMAIL=Hutchrok Intake <intake@hutchrok.com>

# Browser-side Supabase URL/key (not currently used — all DB access via API routes)
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...your-anon-key
